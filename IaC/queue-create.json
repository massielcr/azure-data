{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "The location for the resource group and its metadata."
      }
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "[format('rg-{0}', uniqueString(deployment().name))]",
      "metadata": {
        "description": "The name of the resource group."
      }
    },  
    "storageAccountName": {
      "type": "string",
      "defaultValue": "[format('store{0}', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "The name of the storage account"
      }
    },  
    "storageAccountType": {
      "type": "string",
      "defaultValue": "Standard_LRS",
      "metadata": {
        "description": "Shared parameter used by the storage account step."
      }
    }, 
    "queueName": {
      "type": "string",
      "metadata": {
        "description": "The name of the queue to create."
      }
    },   
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "The tags to apply to the resource group."
      }
    }
  },
  "resources": [
    {
        "type": "Microsoft.Storage/storageAccounts/queueServices/queues",
        "apiVersion": "2026-04-01",
        "name": "[format('{0}/default/{1}', parameters('storageAccountName'), parameters('queueName'))]",
        "dependsOn": [
            "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
        ],
        "properties": {}
    }
  ],
  "outputs": {
    "queueName": {
      "type": "string",
      "value": "[parameters('queueName')]"
    },
    "queueId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Storage/queueServices/queues', 'default', parameters('queueName'))]"
    }
  }
}